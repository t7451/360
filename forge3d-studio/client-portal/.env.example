# ── Forge3D Studio — Client Portal Environment Variables ─────────────────────
#
# Copy this file to .env.local and fill in the values before running
# `npm run dev` or `npm run build`.
#
# Variables prefixed with VITE_ are exposed to the browser bundle.
# Variables without that prefix are only available in build-time scripts.
#
# DO NOT commit .env.local — it is already listed in .gitignore.

# ── API ───────────────────────────────────────────────────────────────────────
# Public URL of the backend (Railway, Render, etc.).
# In production the Netlify _redirects file proxies /api/* to this URL,
# so you do NOT need to expose it in the browser bundle — leave blank if
# you are using the proxy approach.
VITE_API_URL=https://YOUR-ACTUAL-API.up.railway.app

# ── Firebase ──────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
